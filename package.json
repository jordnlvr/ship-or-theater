{
  "name": "ship-or-theater",
  "version": "0.1.0",
  "description": "Evaluate AI claims, demos, and announcements against a fixed, weighted reality rubric and render an honest scorecard.",
  "type": "module",
  "license": "MIT",
  "author": "Kelly Seale",
  "keywords": [
    "ai",
    "evaluation",
    "rubric",
    "scorecard",
    "anthropic",
    "claude",
    "mcp",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ship-or-theater": "dist/cli.js",
    "ship-or-theater-mcp": "dist/mcp.js"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "smoke": "node scripts/smoke.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "commander": "^13.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
